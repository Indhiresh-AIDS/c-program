#include <stdio.h>

int main() {
    float radius, area;
    const float PI = 3.14159;

    printf("Enter the radius of the circle: ");
    scanf("%f", &radius);

    // Formula: PI * radius squared
    area = PI * radius * radius;

    printf("The Area of the circle is: %.2f\n", area);

    return 0;
}
