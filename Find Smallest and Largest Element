#include <stdio.h>

int main() {
    int n, i, smallest, largest;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    int arr[n];

    printf("Enter %d elements: ", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Initialize both with the first element
    smallest = largest = arr[0];

    for(i = 1; i < n; i++) {
        if(arr[i] < smallest) smallest = arr[i]; // Update smallest
        if(arr[i] > largest) largest = arr[i];   // Update largest
    }

    printf("Smallest: %d\nLargest: %d\n", smallest, largest);
    return 0;
}
