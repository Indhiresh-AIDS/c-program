#include <stdio.h>
int main() {
    int number;
    do {
        printf("Enter a positive number: ");
        scanf("%d", &number);
    } while (number <= 0); // Condition is checked AFTER the first run
    printf("You entered: %d\\n", number);
    return 0;
}
